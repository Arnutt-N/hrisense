# ============================================================================
# HRiSENSE — Supabase Production Environment Variables
# ============================================================================
# Usage:
#   cp .env.production.example .env.production
#   # แก้ไขค่าทั้งหมดด้านล่าง
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# Security: อย่า commit ไฟล์ .env.production ขึ้น git
# ============================================================================

# ─── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=<strong-password-here>
POSTGRES_DB=supabase

# ─── Authentication / JWT ──────────────────────────────────────────────
# สร้าง JWT_SECRET ด้วย: openssl rand -base64 32
JWT_SECRET=<random-jwt-secret-32-bytes>
SECRET_KEY_BASE=<random-secret-key-64-bytes>
LOGFLARE_API_KEY=<random-api-key>

# ─── Supabase Keys (generate from supabase CLI or Studio) ─────────────
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Public URLs ───────────────────────────────────────────────────────
SUPABASE_PUBLIC_URL=http://localhost:8000
SITE_URL=http://localhost:3000

# ─── Dashboard / Studio ───────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=<strong-dashboard-password>
STUDIO_ORG_NAME=HRiSENSE
STUDIO_PROJECT_NAME=HRiSENSE Production

# ─── SMTP (สำหรับส่ง email — ใช้ inbucket สำหรับ dev) ──────────────
SMTP_ADMIN_EMAIL=admin@hrisense.local
SMTP_HOST=inbucket
SMTP_PORT=2500
DISABLE_SIGNUP=true

# ─── Port Mapping (เปลี่ยนถ้าต้องการ) ─────────────────────────────────
POSTGRES_PORT=5432
KONG_HTTP_PORT=8000
KONG_SSL_PORT=8443
STUDIO_PORT=3000
AUTH_PORT=9999
REST_PORT=3001
REALTIME_PORT=4000
STORAGE_PORT=5000
META_PORT=8080
INBUCKET_WEB_PORT=9000

# ─── Frontend (Next.js) — ตั้งใน Vercel / app environment ────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=<same-as-SUPABASE_ANON_KEY>
